# Minimal imported target to link against the installed static library
# Adjusted to point to the installed files in this prefix.

if(NOT TARGET resumo::resumo)
  add_library(resumo::resumo STATIC IMPORTED)
  # compute install prefix from this config file location, then build absolute paths
  get_filename_component(_resumo_prefix @RESUMO_PREFIX@ ABSOLUTE)
  set(_resumo_lib_abs "${_resumo_prefix}/lib/libresumo.a")
  # compute absolute include dir path to avoid "non-existent path" checks
  # the install layout places headers in <prefix>/include, so go up three levels
  get_filename_component(_resumo_include_dir "${_resumo_prefix}/include" ABSOLUTE)
  set_target_properties(resumo::resumo PROPERTIES
    IMPORTED_LOCATION "${_resumo_lib_abs}"
    INTERFACE_INCLUDE_DIRECTORIES "${_resumo_include_dir}"
  )
endif()
